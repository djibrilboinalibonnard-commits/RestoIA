# ──────────────────────────────────────────────────────────────────────────
# VoxEmploy — variables d'environnement
# Copier ce fichier vers .env puis remplir les valeurs.
# AUCUN secret ne doit être commité.
# ──────────────────────────────────────────────────────────────────────────

# Base de données PostgreSQL (Railway/Neon en prod, locale en dev)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/voxemploy_dev"

# Better Auth — générer avec : openssl rand -base64 32
BETTER_AUTH_SECRET="changez-moi-32-caracteres-minimum-svp"
# URL publique de l'application (http://localhost:3000 en dev)
BETTER_AUTH_URL="http://localhost:3000"

# ── Phase 2 : agent vocal ──────────────────────────────────────────────────
# VAPI_API_KEY=""
# VAPI_WEBHOOK_SECRET=""
# ANTHROPIC_API_KEY=""
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_SMS_FROM="VoxEmploy"
# S3_ENDPOINT=""            # ex. https://s3.fr-par.scw.cloud
# S3_REGION="fr-par"
# S3_BUCKET="voxemploy-audio"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

